# ============================================================
# BizClaw Environment Variables
# Bizgenix AI Solutions Pvt. Ltd.
#
# For single-tenant: cp .env.example .env
# For multi-tenant: each client gets own .env (auto-generated by new-client.sh)
# ============================================================

# -- REQUIRED (at least one LLM key) --

# Google Gemini (recommended — primary model, free/cheap)
GOOGLE_API_KEY=

# GPT-4o (fallback for complex tasks)
OPENAI_API_KEY=

# Claude (optional — best for Indian business context but costs more)
ANTHROPIC_API_KEY=

# -- CLIENT IDENTITY --

# Client name (shown in dashboard and greetings)
CLIENT_NAME=BizClaw Demo
CLIENT_BUSINESS=Technology

# Gateway auth token (auto-generated per client by new-client.sh)
# Generate manually: openssl rand -hex 24
GATEWAY_TOKEN=change-me-to-a-strong-random-string

# -- CHANNELS --

# Telegram bot token (create via @BotFather)
TELEGRAM_BOT_TOKEN=

# WhatsApp connects via QR scan on first launch — no token needed
# Session stored in: /data/.openclaw/whatsapp-session/

# -- DEPLOYMENT --

# Custom port (default: 18789, each client needs unique port)
BIZCLAW_PORT=18789

# -- OPTIONAL --

# Web search (for market research features)
BRAVE_API_KEY=

# API key rotation (comma-separated for high volume)
# GOOGLE_API_KEYS=key1,key2
# OPENAI_API_KEYS=sk-key1,sk-key2
