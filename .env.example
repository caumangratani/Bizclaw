# ============================================================
# BizClaw Environment Variables
# Bizgenix AI Solutions Pvt. Ltd.
#
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# -- REQUIRED --

# Gateway authentication token (generate a strong random string)
# Used to access the BizClaw control panel and API
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-strong-random-string

# At least ONE LLM API key is required
# Claude (recommended — best for Indian business context)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# GPT-4o (fallback)
OPENAI_API_KEY=sk-your-key-here

# -- OPTIONAL --

# Google Gemini (alternative/fallback)
GEMINI_API_KEY=

# API key rotation (comma-separated for high volume)
# ANTHROPIC_API_KEYS=sk-ant-key1,sk-ant-key2
# OPENAI_API_KEYS=sk-key1,sk-key2

# Web search (for market research features)
BRAVE_API_KEY=

# Custom port (default: 18789)
BIZCLAW_PORT=18789
