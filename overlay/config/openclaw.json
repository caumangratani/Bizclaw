{
  // ============================================================
  // BizClaw — OpenClaw Configuration
  // Bizgenix AI Solutions Pvt. Ltd.
  // ============================================================

  "$schema": "https://openclaw.ai/schema/openclaw.json",

  // -- UI Branding --
  "ui": {
    "seamColor": "#16A34A",
    "assistant": {
      "name": "BizClaw",
      "avatar": ""
    }
  },

  // -- Agent Configuration --
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4.6",
        "fallbacks": ["openai/gpt-5.4"]
      },
      "heartbeat": {
        "every": "4h",
        "target": "whatsapp",
        "prompt": "Check the time (IST). If morning (6-10 AM): send daily report with priorities, compliance alerts, collections summary, and motivational tip. If midday (11 AM-2 PM): flag overdue follow-ups and pending team tasks. If evening (4-8 PM): wrap up summary. Keep under 200 words. Use Hindi phrases naturally. Follow the daily-report skill format.",
        "session": "heartbeat"
      },
      "timeoutSeconds": 300,
      "maxConcurrent": 2,
      "sandbox": { "mode": "off" }
    },
    "list": [
      {
        "id": "bizclaw-main",
        "default": true,
        "name": "BizClaw Assistant",
        "identity": {
          "name": "BizClaw",
          "avatar": ""
        },
        "tools": {
          "profile": "messaging",
          "allow": ["web_fetch", "web_search", "cron", "image", "message"],
          "deny": ["bash", "computer"],
          "exec": { "security": "deny" }
        }
      }
    ]
  },
  "tools": {
    "media": {
      "concurrency": 2,
      "image": {
        "enabled": true,
        "models": [
          { "provider": "anthropic", "model": "claude-sonnet-4-6" }
        ]
      },
      "audio": {
        "enabled": true,
        "models": [
          { "provider": "openai", "model": "gpt-4o-mini-transcribe" }
        ]
      }
    }
  },

  // -- Channel Bindings --
  "bindings": [
    {
      "agentId": "bizclaw-main",
      "match": { "channel": "whatsapp" }
    }
  ],

  "messages": {
    "ackReactionScope": "group-mentions"
  },

  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerAllowFrom": ["918200858674"],
    "ownerDisplay": "raw"
  },

  "cron": {
    "enabled": true,
    "sessionRetention": "7d"
  },

  // -- WhatsApp Channel --
  "web": { "enabled": true },
  "channels": {
    "whatsapp": {
      "accounts": {
        "default": {
          "authDir": "./data/credentials/whatsapp/default",
          "dmPolicy": "allowlist",
          "allowFrom": ["918200858674"],
          "groupPolicy": "disabled"
        }
      },
      "dmPolicy": "allowlist",
      "allowFrom": ["918200858674"],
      "selfChatMode": true,
      "groupPolicy": "disabled",
      "configWrites": true,
      "sendReadReceipts": true,
      "textChunkLimit": 4000,
      "chunkMode": "length",
      "mediaMaxMb": 50,
      "debounceMs": 500,
      "ackReaction": {
        "emoji": "⚡",
        "direct": false,
        "group": "never"
      },
      "actions": {
        "reactions": true,
        "sendMessage": true,
        "polls": true
      }
    }
  },

  // -- Skills (Markdown instructions — no code) --
  "skills": {
    "allowBundled": ["weather", "wacli"],
    "load": {
      "extraDirs": ["./overlay/skills"],
      "watch": true
    },
    "limits": {
      "maxSkillsInPrompt": 20,
      "maxSkillsPromptChars": 50000
    }
  },

  // -- BizClaw Plugin --
  "plugins": {
    "enabled": true,
    "allow": ["bizclaw"],
    "load": {
      "paths": ["./overlay/bizclaw"]
    },
    "entries": {
      "bizclaw": {
        "enabled": true
      }
    }
  },

  // -- Gateway --
  "gateway": {
    "port": 18789,
    "bind": "lan",
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "enabled": true,
      "dangerouslyDisableDeviceAuth": true,
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },

  // -- Memory (persistent per-client storage) --
  "memory": {
    "backend": "builtin",
    "citations": "auto"
  },

  // -- Logging --
  "logging": {
    "level": "info",
    "consoleLevel": "info",
    "redactSensitive": "tools"
  }
}
