{
  "env": {
    "vars": {}
  },
  "logging": {
    "level": "info",
    "consoleLevel": "info",
    "redactSensitive": "tools"
  },
  "update": {
    "checkOnStart": false
  },
  "ui": {
    "seamColor": "#16A34A",
    "assistant": {
      "name": "BizClaw",
      "avatar": "⚡"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
        "fallbacks": [
          "openai/gpt-4o"
        ]
      },
      "heartbeat": {
        "every": "4h",
        "target": "whatsapp",
        "prompt": "Check the time (IST). If morning (6-10 AM): send daily report with priorities, compliance alerts, collections summary, and motivational tip. If midday (11 AM-2 PM): flag overdue follow-ups and pending team tasks. If evening (4-8 PM): wrap up summary. Keep under 200 words. Use Hindi phrases naturally. Follow the daily-report skill format.",
        "session": "heartbeat"
      },
      "workspace": "${OPENCLAW_WORKSPACE_DIR}",
      "timeoutSeconds": 300,
      "maxConcurrent": 2,
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "5m"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "sandbox": { "mode": "off" }
    },
    "list": [
      {
        "id": "bizclaw-TEMPLATE",
        "default": true,
        "name": "BizClaw Assistant",
        "identity": {
          "name": "BizClaw",
          "avatar": "⚡"
        },
        "tools": {
          "profile": "messaging",
          "allow": ["web_fetch", "web_search", "cron", "image", "message"],
          "deny": ["bash", "computer"],
          "exec": { "security": "deny" }
        }
      }
    ]
  },
  "tools": {
    "media": {
      "concurrency": 2,
      "image": {
        "enabled": true,
        "models": [
          { "provider": "anthropic", "model": "claude-sonnet-4-6" }
        ]
      },
      "audio": {
        "enabled": true,
        "models": [
          { "provider": "openai", "model": "gpt-4o-mini-transcribe" }
        ]
      }
    }
  },
  "bindings": [
    {
      "agentId": "bizclaw-TEMPLATE",
      "match": { "channel": "whatsapp" }
    }
  ],
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerAllowFrom": ["OWNER_PHONE"],
    "ownerDisplay": "raw"
  },
  "cron": {
    "enabled": true,
    "sessionRetention": "7d"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": { "enabled": true },
        "command-logger": { "enabled": true },
        "session-memory": { "enabled": true }
      }
    }
  },
  "web": { "enabled": true },
  "channels": {
    "whatsapp": {
      "accounts": {
        "default": {
          "authDir": "./data/credentials/whatsapp/default",
          "dmPolicy": "allowlist",
          "allowFrom": ["OWNER_PHONE"],
          "groupPolicy": "disabled"
        }
      },
      "dmPolicy": "allowlist",
      "allowFrom": ["OWNER_PHONE"],
      "selfChatMode": true,
      "groupPolicy": "disabled",
      "configWrites": true,
      "sendReadReceipts": true,
      "textChunkLimit": 4000,
      "chunkMode": "length",
      "mediaMaxMb": 50,
      "debounceMs": 500,
      "ackReaction": {
        "emoji": "⚡",
        "direct": false,
        "group": "never"
      },
      "actions": {
        "reactions": true,
        "sendMessage": true,
        "polls": true
      }
    }
  },
  "gateway": {
    "port": 18789,
    "bind": "lan",
    "controlUi": {
      "enabled": true,
      "root": "./overlay/control-ui",
      "dangerouslyDisableDeviceAuth": true,
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "allowedOrigins": [
        "https://claw.bizgenix.ai"
      ]
    },
    "trustedProxies": ["127.0.0.1", "::1"],
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "memory": {
    "backend": "builtin",
    "citations": "auto"
  },
  "skills": {
    "allowBundled": ["weather", "wacli"],
    "load": {
      "extraDirs": ["./overlay/skills"],
      "watch": true
    },
    "limits": {
      "maxSkillsInPrompt": 20,
      "maxSkillsPromptChars": 50000
    }
  },
  "plugins": {
    "enabled": true,
    "allow": ["bizclaw"],
    "load": {
      "paths": ["./overlay/bizclaw"]
    },
    "entries": {
      "whatsapp": { "enabled": true },
      "bizclaw": { "enabled": true }
    }
  }
}
